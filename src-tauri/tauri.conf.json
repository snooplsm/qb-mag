{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QB Mag",
  "version": "0.1.0",
  "identifier": "app.rprtd.qbmag",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "QB Mag",
        "width": 870,
        "height": 640,
        "resizable": true,
        "titleBarStyle": "Overlay"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
